# Commands
eval "$(rbenv init - zsh)"
eval "$(hub alias -s)"

# Unix
alias zr="source ~/.zlogin && source ~/.zshrc"
alias e="$EDITOR"
alias v="$VISUAL"
alias vi="$VISUAL"
alias vim="$VISUAL"
alias ae="v ~/.zsh/aliases"
alias c="clear"
alias l='ls -1'
alias ll='ls -al'
alias lh='ls -Alh'
alias mkdir='mkdir -p'

# Bundler
alias b="bundle"
alias be="bundle exec"

# Rubygems
alias gi="gem install"
alias giv="gem install -v"

# Rails
alias lg="tail -f log/development.log"
alias migrate="rake db:migrate db:rollback && rake db:migrate db:test:prepare"
alias s="rspec"

# Git
alias g="git"
alias gs="git status"
alias gps="git push"
alias gpl="git fetch && git pull --rebase"
alias gb="git branch"
alias gf="git fetch"
alias gd="git diff"
alias gap="git add -p"
alias gc="git commit"
alias gco="git checkout"
alias gpr="git pull-request"
alias gbr="git browse"
alias gl="git log --pretty=oneline --abbrev-commit"
alias gt="!git clone --depth 1 --origin source"
alias gg="git rev-list --all | xargs git grep"
alias staging="gco staging; gf origin staging; git reset --hard origin/staging"
alias master="gco master; gpl"

# Tmux
alias tn="tmux -u -S /tmp/pair new -s"
alias ta="tmux -u -S /tmp/pair attach -t"
alias tl="tmux -u -S /tmp/pair ls"
alias tk="tmux -u -S /tmp/pair kill-session -t"

# Apache
alias vhosts="v /etc/apache2/extra/httpd-vhosts.conf"

# PCO Box
alias pb="pco box"
alias pba="pco box apprestart"
alias pbc="pco box rails c"
alias pbb="pco box bundle"
alias pbm="pco box rake db:migrate"

# Misc
alias x="exercism"
alias ex="elixir"
alias love="/Applications/love.app/Contents/MacOS/love"
alias pico="/Applications/PICO-8.app/Contents/MacOS/pico8"
