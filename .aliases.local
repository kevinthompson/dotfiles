# Generic
alias ae="v ~/.aliases.local"
alias zr="source ~/.zlogin && source ~/.zshrc"

# Git
alias gs="git status"
alias gps="git push"
alias gpl="git pull"
alias gb="git branch"
alias gf="git fetch"
alias gd="git diff"
alias gap="git add -p"
alias gc="git commit"
alias gco="git checkout"
alias gpr="git pull-request"
alias gbr="git browse"
alias gl="git log --pretty=oneline --abbrev-commit"

# Rails
alias lg="tail -f log/development.log"
alias be="bundle exec"

alias c="clear"
